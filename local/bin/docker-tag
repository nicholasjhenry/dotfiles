#!/bin/bash
#
# Search Docker Hub for hexpm/elixir image tags matching an OS, an Elixir
# version, and an Erlang/OTP version.
#
# Usage:
#
#    docker-tag OS ELIXIR_VSN ERLANG_VSN
#
# Example:
#
#    docker-tag debian 1.15.7 26.1.2
#

# Fetch one page of tag names, newest-sorted.
function fetch_page() {
  local page=$1

  curl --silent \
    "https://hub.docker.com/v2/namespaces/hexpm/repositories/elixir/tags?page_size=100&page=${page}" |
    jq -r ".results[].name" | sort --version-sort
}

if [ "$#" -ne 3 ]; then
  echo "Usage: $0 OS ELIXIR_VSN ERLANG_VSN"
  exit 1
fi

os=$1
elixir_vsn=$2
erlang_vsn=$3

echo "Start Docker Hub search..."
page=1

while true; do
  echo "Searching page ${page}..."
  tags=$(fetch_page "$page")

  # An empty page means we have walked past the last tag; stop paging.
  if [ -z "$tags" ]; then
    echo "No more tags; done."
    break
  fi

  result=$(echo "$tags" | grep "$os" | grep "$elixir_vsn" | grep "$erlang_vsn")

  if [ -n "$result" ]; then
    echo "$result"
    echo "Continue? Press any key or Ctrl-C to exit."
    read -r input
  else
    echo "No matches on this page, continue searching..."
  fi

  ((page++))
done
