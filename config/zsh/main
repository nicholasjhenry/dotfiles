# Gray color for autosuggestions
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=247'

setopt INTERACTIVE_COMMENTS

export WORKSPACES=$HOME/Workspaces

source $HOME/.config/zsh/plugins

source $HOME/.config/zsh/aliases
source $HOME/.config/zsh/bindkey
source $HOME/.config/zsh/elixir
source $HOME/.config/zsh/env
source $HOME/.config/zsh/flaker
source $HOME/.config/zsh/git-prompt
source $HOME/.config/zsh/fzf
source $HOME/.config/zsh/homebrew
source $HOME/.config/zsh/mise
source $HOME/.config/zsh/pnpm

fpath=( ~/.zsh-completions $fpath )

[ -f $WORKSPACES/dotfiles.secret/shrc ] && source $WORKSPACES/dotfiles.secret/shrc
