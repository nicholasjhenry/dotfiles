# Gray color for autosuggestions
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=247'

setopt INTERACTIVE_COMMENTS
setopt AUTOCD
setopt NOBEEP
setopt NUMERIC_GLOB_SORT  # sort file10 after file9, not after file1

export WORKSPACES=$HOME/Workspaces

# NOTE: Must run in this order
# plugins populates fpath (zsh-completions) → completion runs compinit → aliases uses compdef
source $ZDOTDIR/env
source $ZDOTDIR/plugins
source $ZDOTDIR/completion

# Custom
source $ZDOTDIR/aliases
source $ZDOTDIR/bindkey
source $ZDOTDIR/elixir
source $ZDOTDIR/flaker
source $ZDOTDIR/fzf
source $ZDOTDIR/history
source $ZDOTDIR/homebrew
source $ZDOTDIR/mise
source $ZDOTDIR/pnpm
source $ZDOTDIR/prompt

fpath=( ~/.zsh-completions $fpath )

[ -f $XDG_CONFIG_HOME/secrets/shrc ] && source $XDG_CONFIG_HOME/secrets/shrc
