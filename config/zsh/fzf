# https://github.com/junegunn/fzf
#
# Load fzf's shell integration (key bindings + completion) directly from the
# binary via `fzf --zsh` (fzf >= 0.48), instead of the generated ~/.fzf.zsh.
# This works no matter how fzf was installed:
#   - Homebrew: already on PATH
#   - git method (~/.fzf, see vimrc.bundles): added to PATH below

export FZF_DEFAULT_COMMAND='fd --type f'

export FZF_DEFAULT_OPTS='
  --height=60%
  --layout=reverse
  --border=rounded
  --preview-window=right:65%:wrap:border-left
'

if command -v bat >/dev/null; then
  export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=plain,numbers --line-range=:500 {}'"
fi

# The git install isn't on PATH by default; add it. Skipped for Homebrew.
if [[ -d ~/.fzf/bin && ":$PATH:" != *":$HOME/.fzf/bin:"* ]]; then
  PATH="$PATH:$HOME/.fzf/bin"
fi

command -v fzf >/dev/null && source <(fzf --zsh)
